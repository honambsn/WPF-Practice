<Window x:Class="Go.UI.Demo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Go.UI"
        mc:Ignorable="d"
        Title="Pulse Demo"
        Width="800"
        Height="800"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!--header/info panel-->
        <Border Grid.Row="0"
                Background="#1e1e1e"
                Padding="15"
                BorderBrush="#ab810f"
                BorderThickness="0 0 0 2">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <TextBlock Text="Current Turn: "
                           Foreground="White"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <Ellipse x:Name="TurnIndicator"
                         Width="20"
                         Height="20"
                         Fill="Black"
                         Margin="10 0 20 0"
                         Stroke="White"
                         StrokeThickness="2"/>

                <TextBlock Text="R to Reset"
                           Foreground="#999"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Game board -->
        <Viewbox Grid.Row="1" 
                Margin="20">
            <Border Padding="20"
                    Background="#DEB887"
                    BorderBrush="#8B4513"
                    BorderThickness="3"
                    CornerRadius="5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" 
                                    ShadowDepth="5" 
                                    Opacity="0.5"/>
                </Border.Effect>

                <!-- Board container -->
                <Grid Width="650" 
                      Height="650">

                    <!-- Background gradient for wood effect -->
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E5B566" Offset="0"/>
                            <GradientStop Color="#D4A849" Offset="0.5"/>
                            <GradientStop Color="#E5B566" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- Layer 1: Board lines -->
                    <Canvas x:Name="BoardCanvas"
                           Panel.ZIndex="1"/>

                    <!-- Layer 2: Intersection clickable areas -->
                    <Canvas x:Name="IntersectionGrid"
                           Panel.ZIndex="2"/>

                    <!-- Layer 3: Stones -->
                    <Canvas x:Name="StoneCanvas"
                           Panel.ZIndex="3"/>
                </Grid>
            </Border>
        </Viewbox>
    </Grid>
</Window>