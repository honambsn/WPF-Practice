  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Go.Application\Go.Application.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Resources\Images\board_1.png" />
    <Resource Include="Resources\Images\board_2.png" />
